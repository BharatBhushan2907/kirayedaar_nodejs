# ── Server ──────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/kirayedar?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# ── SMS Gateway (production) ─────────────────────────────────────────────────
